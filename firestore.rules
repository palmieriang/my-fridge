rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedPositiveNumber(value) {
      return (value is int || value is float) && value > 0;
    }

    function isValidProductData(data) {
      return data.keys().hasAll(['name', 'date', 'place']) &&
        data.keys().hasOnly(['name', 'date', 'place', 'quantity', 'createdAt']) &&
        data.name is string &&
        data.name.size() >= 1 &&
        data.name.size() <= 100 &&
        data.date is string &&
        data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.place is string &&
        data.place in ['fridge', 'freezer'] &&
        (!('quantity' in data) || isSignedPositiveNumber(data.quantity));
    }

    function isValidShoppingItemData(data) {
      return data.keys().hasAll(['name', 'checked']) &&
        data.keys().hasOnly(['name', 'checked', 'createdAt']) &&
        data.name is string &&
        data.name.size() >= 1 &&
        data.name.size() <= 120 &&
        data.checked is bool;
    }

    match /users/{userId} {
      // Users can only read and write their own document.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /products/{productId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null &&
          request.auth.uid == userId &&
          isValidProductData(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /shoppingItems/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null &&
          request.auth.uid == userId &&
          isValidShoppingItemData(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
